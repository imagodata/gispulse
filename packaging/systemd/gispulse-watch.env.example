# GISPulse watch — environment file template.
#
# Copy to /etc/gispulse/<instance>.env and customise. The instance name
# (`<instance>`) maps to the systemd unit instance:
#
#     cp gispulse-watch.env.example /etc/gispulse/parcels.env
#     # edit GISPULSE_GPKG / GISPULSE_RULES below
#     systemctl daemon-reload
#     systemctl enable --now gispulse-watch@parcels
#
# Lines starting with '#' are comments. Quote values that contain spaces.

# --- Required ---------------------------------------------------------------

# Absolute path to the GeoPackage to watch.
GISPULSE_GPKG=/var/lib/gispulse/parcels.gpkg

# Absolute path to the rules YAML (same format as `gispulse triggers run --config`).
GISPULSE_RULES=/etc/gispulse/parcels.rules.yaml

# --- Optional (override the unit's defaults) -------------------------------

# Poll interval in milliseconds. Default 500. Lower = lower latency, higher CPU.
# GISPULSE_POLL_MS=500

# Max change-log rows pulled per tick. Default 200.
# GISPULSE_BATCH_LIMIT=200

# Collapse ticks pulling >= N rows into a single bulk.changed event instead
# of broadcasting + evaluating per row. 0 (default) keeps per-row behaviour.
# Recommended for production: set to ~1000 to absorb ogr2ogr appends without
# webhook flooding.
# GISPULSE_BULK_THRESHOLD=1000

# Stable identifier stamped on every event (multi-tenant disambiguation).
# Defaults to the systemd instance name (e.g. "parcels" for gispulse-watch@parcels).
# GISPULSE_DATASET_ID=parcels-prod

# --- Webhook destinations (passed via --webhook) ---------------------------

# The unit's ExecStart does NOT pass --webhook by default; if you want to
# add an allowlist beyond what's declared in the YAML's security.webhook_allowlist,
# either edit the unit (systemd drop-in) or extend the YAML.
