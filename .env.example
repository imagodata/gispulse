# ── GISPulse Configuration ────────────────────────────────────────────────
#
# Copy this file to .env and adjust values:
#   cp .env.example .env
#
# Modes:
#   A (Local)  : Only GISPULSE_ENGINE=duckdb needed (default)
#   B (Docker) : Set PostGIS vars below + GISPULSE_ENGINE=postgis
#   C (VPS)    : Use deploy/docker-compose.prod.yml + deploy/.env.example
#   D (Desktop): No config needed (embedded DuckDB)

# ── Engine ────────────────────────────────────────────────────────────────
GISPULSE_ENGINE=duckdb              # duckdb | postgis | hybrid
GISPULSE_STORAGE=sqlite             # sqlite | memory

# ── Tier & License ───────────────────────────────────────────────────────
# Community: pip install gispulse       (DuckDB only, free)
# Pro:       pip install gispulse-pro   (PostGIS, S3, Redis, scheduling)
GISPULSE_TIER=community             # community | pro | enterprise
# GISPULSE_LICENSE_KEY=             # Required for pro/enterprise tiers

# ── PostGIS (Mode B/C only) ──────────────────────────────────────────────
POSTGRES_USER=gispulse
POSTGRES_PASSWORD=gispulse
POSTGRES_DB=gispulse
# GISPULSE_DSN=postgresql://gispulse:gispulse@postgis:5432/gispulse
# GISPULSE_DATABASE_URL=postgresql://gispulse:gispulse@localhost:5433/gispulse

# ── Environment ──────────────────────────────────────────────────────────
# GISPULSE_ENV=development          # development | production

# ── API Server ────────────────────────────────────────────────────────────
# GISPULSE_API_KEYS=key1,key2       # Comma-separated; unset = auth disabled
# GISPULSE_CORS_ORIGINS=*           # Comma-separated allowed origins

# ── OIDC / SSO (Enterprise tier) ─────────────────────────────────────────
# GISPULSE_OIDC_ISSUER=https://auth.example.com/realms/gispulse
# GISPULSE_OIDC_CLIENT_ID=gispulse
# GISPULSE_OIDC_CLIENT_SECRET=
# GISPULSE_OIDC_REDIRECT_URI=https://gispulse.example.com/auth/callback
# GISPULSE_SESSION_SECRET=          # REQUIRED in production when OIDC is enabled
#   Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"

# ── Redis (optional, recommended for multi-worker) ───────────────────────
# GISPULSE_REDIS_URL=redis://localhost:6379
# GISPULSE_RATE_LIMIT_STORAGE=      # Override: redis://... or memory://

# ── Portal ────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8001

# ── PostGIS DSN for portal SQL/capabilities (optional) ───────────────────
# GISPULSE_POSTGIS_DSN=postgresql://gispulse:gispulse@postgis:5432/gispulse
