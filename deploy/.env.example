# ── GISPulse VPS Production — Environment Variables ──────────────────────
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# ── Domain (used by Caddy for auto-TLS) ─────────────────────────────────
DOMAIN=gispulse.example.com

# ── PostgreSQL ───────────────────────────────────────────────────────────
PG_USER=gispulse
PG_PASSWORD=CHANGE_ME_strong_password_here
PG_DB=gispulse

# ── GISPulse API ─────────────────────────────────────────────────────────
GISPULSE_ENV=production
API_KEYS=sk-your-api-key-1,sk-your-api-key-2
API_WORKERS=4
CORS_ORIGINS=https://gispulse.example.com

# ── OIDC / SSO (Enterprise tier) ────────────────────────────────────────
# GISPULSE_OIDC_ISSUER=https://auth.example.com/realms/gispulse
# GISPULSE_OIDC_CLIENT_ID=gispulse
# GISPULSE_OIDC_CLIENT_SECRET=
# GISPULSE_OIDC_REDIRECT_URI=https://gispulse.example.com/auth/callback
# GISPULSE_SESSION_SECRET=          # REQUIRED — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"

# ── PostGIS DSN for portal SQL/capabilities ──────────────────────────────
GISPULSE_POSTGIS_DSN=postgresql://${PG_USER}:${PG_PASSWORD}@postgis:5432/${PG_DB}

# ── Grafana ──────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_grafana_password
GRAFANA_PORT=3000

# ── Backup ───────────────────────────────────────────────────────────────
BACKUP_KEEP_DAYS=30

# ── Demo-mode Pro bypass (docker-compose.demo.yml only) ──────────────────
# Unlocks Pro capabilities for public showcase deployments. Requires BOTH
# a runtime token provisioned from GitHub Actions secrets and its SHA-256
# digest. Without the matching pair, GISPULSE_DEMO_MODE alone is a no-op.
#
# Generate a new token pair with:
#   TOKEN=$(openssl rand -hex 32)
#   DIGEST=$(printf '%s' "$TOKEN" | sha256sum | awk '{print $1}')
#   echo "token=$TOKEN digest=$DIGEST"
#
# Store the token in the GitHub Actions secret GISPULSE_DEMO_TOKEN and the
# digest in GISPULSE_DEMO_TOKEN_SHA256; the deploy workflow injects them
# into this .env. The digest is non-secret; the token must never leak.
GISPULSE_DEMO_TOKEN=
GISPULSE_DEMO_TOKEN_SHA256=
